annotation PBI_QueryOrder = ["Row - Column base","Rows","Columns","Population","Age Categories","Geography - ABS Sort","Geography","covid-live - base","covid-live","Report Dates - base","Report Dates - latest","Report Dates - base cases","Report Dates - latest cases","Report Dates","Daily Doses Administered - aus","Daily Doses Administered - nsw","Daily Doses Administered - vic","Daily Doses Administered - qld","Daily Doses Administered - sa","Daily Doses Administered - wa","Daily Doses Administered - tas","Daily Doses Administered - nt","Daily Doses Administered - act","Daily Doses Administered","Infection Fatality Rate","Dates","COP files","ABS Doctor certified deaths weekly 2015-2021","ABS Doctor certified deaths weekly 2022-2023","ABS Doctor certified deaths weekly 2024","ABS Doctor certified deaths weekly 2025","ABS Doctor certified deaths","ABS Doctor certified deaths - for ADHAC","Death Toll","Days since Health Leadership faced the public on COVID","health-aged-care xlsx file","Health Aged Care - Treatments","Health Aged Care - National Snapshot","Health Aged Care - Active Outbreak Summary","Aged Care Service List","Aged Care - Active Outbreaks","Aged Care - Active Outbreaks - DV Service Name","Aged Care Service Name Fuzzy Matches","AUS_AgedCare csv file","AUS_AgedCare","AUS_COVID19Cases xlsx file","COVID-19 Cases Monthly","COVID-19 Cases Daily","AUS_COVID19Data_Monthly xlsx file","COVID-19 associated deaths","COVID-19 impact on aged care","COVID-19 impact on aged care AUS","COVID-19 impact on hospitals","COVID-19 treatments","COVID-19 treatments AUS","COVID-19 vaccine booster doses","ADHAC","Data Sources","Metrics","NNDSS-COVID-19","NNDSS-Influenza","NNDSS-Measles","NNDSS-RSV","NNDSS - daily dates","NNDSS - base","NNDSS - AUS","NNDSS","Year","Month","ABS ARI deaths","Population by SA3"]

annotation __PBI_TimeIntelligenceEnabled = 1


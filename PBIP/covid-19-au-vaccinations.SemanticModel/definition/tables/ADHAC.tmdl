	measure '# Aged Care Active Outbreaks (7-day avg)' = ```
			
			VAR v_End_Date = LASTDATE( 'ADHAC'[Report Date] ) 
			VAR v_Start_Date = v_End_Date - ( [^ Rolling Average Days Value] - 1 )
			RETURN
			IF ( [# Aged Care Active Outbreaks] > 0 ,
			    CALCULATE (
			        SUMX( 
			            FILTER (
			                Dates ,
			                'Dates'[Date] >= v_Start_Date
			                    && 'Dates'[Date]  <= v_End_Date
			            ),
			            [# Aged Care Active Outbreaks] 
			        ) / [^ Rolling Average Days Value] ,
			        ALL( 'Dates' ),
			        ALL( 'ADHAC'[Report Date] )
			    )
			)
			
			```
		formatString: #,0
		lineageTag: 97faee98-a995-4bbe-94dd-313b8e049db2

		annotation PBI_FormatHint = {"isDecimal":true}


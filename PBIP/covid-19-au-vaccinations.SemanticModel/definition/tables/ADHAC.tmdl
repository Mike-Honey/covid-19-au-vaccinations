		formatString: #,0
		lineageTag: 5d6979fa-5625-4f18-87c7-d7c0bcb07507

		annotation PBI_FormatHint = {"isDecimal":true}

	measure '# Resident Cases (Daily) - Residential Aged Care' = ```
			
			VAR v_Date = MAX ( Dates[Date] )
			VAR v_Latest_Date = 
			CALCULATE( 
			    MIN( ADHAC[Report Date] ), 
			    ADHAC[Category] = "Aged Care" ,
			    ADHAC[Metric] = "Aged Care Resident Cases",
			    ALL ( Dates ),
			    ADHAC[Report Date] >= v_Date
			)
			VAR v_Prior_Date = 
			CALCULATE( 
			    MAX( ADHAC[Report Date] ), 
			    ADHAC[Category] = "Aged Care" ,
			    ADHAC[Metric] = "Aged Care Resident Cases",
			    ALL ( Dates ),
			    ADHAC[Report Date] < v_Latest_Date
			)
			RETURN
			DIVIDE(
			    CALCULATE( 
			        LASTNONBLANK( ADHAC[Value], VALUES( Dates[Date] ) ), 
			        ADHAC[Category] = "Aged Care" ,
			        ADHAC[Metric] = "Aged Care Resident Cases",
			        ALL ( Dates ),
			        Dates[Date] = v_Latest_Date
			    ) ,
			    v_Latest_Date - v_Prior_Date
			)
			```
		formatString: #,0
		lineageTag: 7d3aa678-a3a9-4430-ac7d-4971914b0a4b

		annotation PBI_FormatHint = {"isDecimal":true}


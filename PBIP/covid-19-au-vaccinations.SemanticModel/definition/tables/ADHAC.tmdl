			VAR v_Earliest_Date = CALCULATE ( LASTDATE( 'ADHAC'[Report Date] ) , ALL ( 'ADHAC'[Report Date] ) , ADHAC[Metric] = "Monthly PBS Scripts" , ADHAC[Value] > 0 , 'ADHAC'[Report Date] < v_End_Date )

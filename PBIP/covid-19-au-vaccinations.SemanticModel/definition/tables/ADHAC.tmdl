	measure '% Aged Care Active Outbreaks Weekly Change' = ```
			
			VAR v_End_Date = CALCULATE ( LASTDATE( 'ADHAC'[Report Date] ) , ADHAC[Metric] = "Daily Cases" , ADHAC[Value] > 0 )
			VAR v_Earliest_Date = CALCULATE ( FIRSTDATE( 'ADHAC'[Report Date] ) , ALL ( 'ADHAC'[Report Date] ) , 'ADHAC'[Report Date] < v_End_Date )
			RETURN
			    IF ( v_End_Date - v_Earliest_Date >= 13, 
			        DIVIDE( 
			            CALCULATE( [# Aged Care Active Outbreaks (7-day avg)] , 
			                ALL ( 'ADHAC'[Report Date] ) , 
			                FILTER ( ALL ( Dates ) ,  
			                    'Dates'[Date] >= v_End_Date - 6 &&
			                     'Dates'[Date] <= v_End_Date
			                )
			            ),
			            CALCULATE( [# Aged Care Active Outbreaks (7-day avg)] , 
			                ALL ( 'ADHAC'[Report Date] ) , 
			                FILTER ( ALL ( Dates ) ,  
			                    'Dates'[Date] >= v_End_Date - 13 &&
			                     'Dates'[Date] <= v_End_Date - 7
			                )
			            )
			        ) - 1
			    )
			```
		formatString: 0%;-0%;0%
		lineageTag: bbb7e739-0e2c-498c-8659-505adcede234


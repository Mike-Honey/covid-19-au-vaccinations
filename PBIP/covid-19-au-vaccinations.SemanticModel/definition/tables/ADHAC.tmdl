	measure '# Molnupiravir Prescriptions (Daily) - Residential Aged Care' = ```
			
			VAR v_Date = MAX ( Dates[Date] )
			VAR v_Current_Value = 
			CALCULATE( 
			    MAX( ADHAC[Value] ), 
			    ADHAC[Category] = "Treatments" ,
			    ADHAC[Metric] = "Molnupiravir Prescriptions",
			    ALL ( Dates ),
			    ADHAC[Report Date] = v_Date
			)
			VAR v_Latest_Date = 
			CALCULATE( 
			    MIN( ADHAC[Report Date] ), 
			    ADHAC[Category] = "Treatments" ,
			    ADHAC[Metric] = "Molnupiravir Prescriptions",
			    ALL ( Dates ),
			    ADHAC[Report Date] <= v_Date,
			    ADHAC[Value] = v_Current_Value
			)
			VAR v_Prior_Value = 
			CALCULATE( 
			    MAX( ADHAC[Value] ), 
			    ADHAC[Category] = "Treatments" ,
			    ADHAC[Metric] = "Molnupiravir Prescriptions", 
			    ALL ( Dates ),
			    ADHAC[Report Date] < v_Latest_Date,
			    ADHAC[Value] < v_Current_Value
			)
			VAR v_Prior_Date = 
			CALCULATE( 
			    MIN( ADHAC[Report Date] ), 
			    ADHAC[Category] = "Treatments" ,
			    ADHAC[Metric] = "Molnupiravir Prescriptions", 
			    ALL ( Dates ),
			    ADHAC[Report Date] < v_Latest_Date,
			    ADHAC[Value] = v_Prior_Value
			)
			RETURN 
			DIVIDE(
			    v_Current_Value - v_Prior_Value,
			    v_Latest_Date - v_Prior_Date - 1
			)
			```
		lineageTag: 6912e5b0-e54f-4eee-aa9d-2a907f850ece

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '% Molnupiravir Prescriptions per Case - Residental Aged Care' = ```
			
			DIVIDE( 
			    SUMX ( Dates , [# Molnupiravir Prescriptions (Daily) - Residential Aged Care] ), 
			    SUMX ( Dates , ( [# Resident Cases (Weekly) - Residential Aged Care] / 7 ) )
			)
			
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 19e77e9b-c693-4221-be9b-43fbcf35a2b7

	measure '# Staff Cases (Weekly) - Residential Aged Care' = ```
			
			VAR v_Report_Date = 
			CALCULATE( MAX ( ADHAC[Report Date] ),
			    ADHAC[Category] = "Aged Care"  ,
			    ADHAC[Metric] = "Aged Care Staff Cases" ,
			    ADHAC[Value] >= 0
			)
			VAR v_Prior_Report_Date =
			CALCULATE( MAX ( ADHAC[Report Date] ),
			    ADHAC[Category] = "Aged Care"  ,
			    ADHAC[Metric] = "Aged Care Staff Cases" ,
			    ALL ( Dates ) ,
			    ADHAC[Report Date] < v_Report_Date ,
			    ADHAC[Value] >= 0
			)
			RETURN
			COALESCE(
			    CALCULATE( 
			        ADHAC[# Value ADHAC], 
			        ADHAC[Category] = "Aged Care" ,
			        ADHAC[Metric] = "Staff Cases - Cumulative increase (7 days)" 
			    ),
			    CALCULATE( 
			        ADHAC[# Value ADHAC], 
			        ADHAC[Category] = "Aged Care" ,
			        ADHAC[Metric] = "Aged Care Weekly Staff Cases" 
			    ),
			    CALCULATE( 
			        ADHAC[# Value ADHAC], 
			        ADHAC[Category] = "Aged Care" ,
			        ADHAC[Metric] = "Aged Care Staff Cases" 
			    ) -
			    CALCULATE( 
			        ADHAC[# Value ADHAC], 
			        ADHAC[Category] = "Aged Care" ,
			        ADHAC[Metric] = "Aged Care Staff Cases" ,
			        ALL ( Dates ),
			        Dates[Date] = v_Prior_Report_Date
			    )
			)
			```
		lineageTag: 43ef9fc5-047e-4bc3-b056-7788d4d32a04

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '# Staff Cases (Weekly) per 1M -  Residential Aged Care' = DIVIDE( [# Staff Cases (Weekly) - Residential Aged Care] , ( [# Population] / 1000000 ) )
		formatString: #,0.0
		lineageTag: 8078811e-83a3-4f73-bfb2-35b0d5bac47a

	measure '# Resident Cases (Weekly) - Residential Aged Care' = ```
			
			VAR v_Report_Date = 
			CALCULATE( MAX ( ADHAC[Report Date] ),
			    ADHAC[Category] = "Aged Care"  ,
			    ADHAC[Metric] = "Aged Care Resident Cases" ,
			    ADHAC[Value] >= 0
			)
			VAR v_Prior_Report_Date =
			CALCULATE( MAX ( ADHAC[Report Date] ),
			    ADHAC[Category] = "Aged Care"  ,
			    ADHAC[Metric] = "Aged Care Resident Cases" ,
			    ALL ( Dates ) ,
			    ADHAC[Report Date] < v_Report_Date ,
			    ADHAC[Value] >= 0
			)
			RETURN
			COALESCE(
			    CALCULATE( 
			        ADHAC[# Value ADHAC], 
			        ADHAC[Category] = "Aged Care" ,
			        ADHAC[Metric] = "Aged Care Resident Cases" 
			    ) -
			    CALCULATE( 
			        ADHAC[# Value ADHAC], 
			        ADHAC[Category] = "Aged Care" ,
			        ADHAC[Metric] = "Aged Care Resident Cases" ,
			        ALL ( Dates ),
			        Dates[Date] = v_Prior_Report_Date
			    ),
			    CALCULATE( 
			        ADHAC[# Value ADHAC], 
			        ADHAC[Category] = "Aged Care" ,
			        ADHAC[Metric] = "Resident Cases - Cumulative increase (7 days)" 
			    )
			)
			
			```
		formatString: #,0
		lineageTag: 7a2e6fc1-84f2-473e-a521-213c4f381f38

		annotation PBI_FormatHint = {"isDecimal":true}

	measure '% Paxlovid Prescriptions per Case - Residental Aged Care' = ```
			
			DIVIDE( 
			    SUMX ( Dates , [# Paxlovid Prescriptions (Daily) - Residential Aged Care] ), 
			    SUMX ( Dates , ( [# Resident Cases (Weekly) - Residential Aged Care] / 7 ) )
			)
			
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 7c3c33a5-41a7-4e6f-b99a-f237186a4be3

	measure '# Paxlovid Prescriptions (Daily) - Residential Aged Care' = ```
			
			VAR v_Date = MAX ( Dates[Date] )
			VAR v_Current_Value = 
			CALCULATE( 
			    MAX( ADHAC[Value] ), 
			    ADHAC[Category] = "Treatments" ,
			    ADHAC[Metric] = "Paxlovid Prescriptions",
			    ALL ( Dates ),
			    ADHAC[Report Date] = v_Date
			)
			VAR v_Latest_Date = 
			CALCULATE( 
			    MIN( ADHAC[Report Date] ), 
			    ADHAC[Category] = "Treatments" ,
			    ADHAC[Metric] = "Paxlovid Prescriptions",
			    ALL ( Dates ),
			    ADHAC[Report Date] <= v_Date,
			    ADHAC[Value] = v_Current_Value
			)
			VAR v_Prior_Value = 
			CALCULATE( 
			    MAX( ADHAC[Value] ), 
			    ADHAC[Category] = "Treatments" ,
			    ADHAC[Metric] = "Paxlovid Prescriptions", 
			    ALL ( Dates ),
			    ADHAC[Report Date] < v_Latest_Date,
			    ADHAC[Value] < v_Current_Value
			)
			VAR v_Prior_Date = 
			CALCULATE( 
			    MIN( ADHAC[Report Date] ), 
			    ADHAC[Category] = "Treatments" ,
			    ADHAC[Metric] = "Paxlovid Prescriptions", 
			    ALL ( Dates ),
			    ADHAC[Report Date] < v_Latest_Date,
			    ADHAC[Value] = v_Prior_Value
			)
			RETURN 
			DIVIDE(
			    v_Current_Value - v_Prior_Value,
			    v_Latest_Date - v_Prior_Date - 1
			)
			
			```
		formatString: #,0
		lineageTag: d14da3e1-6151-41ba-b843-65809734528d

		annotation PBI_FormatHint = {"isDecimal":true}

	measure '# Molnupiravir Prescriptions - Residential Aged Care' = ```
			
			CALCULATE( 
			    LASTNONBLANK( ADHAC[Value], VALUES( Dates[Date] ) ), 
			    ADHAC[Category] = "Treatments" ,
			    ADHAC[Metric] = "Molnupiravir Prescriptions" 
			) 
			```

table NNDSS
	lineageTag: 7626d95f-6871-4fb2-ad2d-b4bfb2a13ad6

	measure '# Cases (NNDSS)' = ```
			SUM ( 'NNDSS'[CASES] ) 
			```
		formatString: #,0
		lineageTag: 3506685d-b349-452d-a1a8-cf73d6f1edb2

		annotation PBI_FormatHint = {"isDecimal":true}

	measure '# New Cases (NNDSS)' = ```
			
			VAR V_Year = VALUE( MAX ( 'NNDSS'[YEAR] ) )
			VAR v_Previous =
			IF ( V_Year >= 2024,
			    CALCULATE( [# Cases (NNDSS)] , 
			        OFFSET ( -1, 
			            FILTER( 
			                ALL ( 'Dates' ),
			                [# Cases (NNDSS)] > 0
			            ),
			            ORDERBY ( [Date],ASC ), ,
			            PARTITIONBY ( [Year] )
			        )
			    )
			)
			RETURN
			IF ( V_Year < 2024,
			    [# Cases (NNDSS)],
			    SWITCH ( TRUE() ,
			        v_Previous = 0 , [# Cases (NNDSS)] ,
			        v_Previous > 0 && [# Cases (NNDSS)] > 0 , [# Cases (NNDSS)] - v_Previous 
			    )
			)
			```
		lineageTag: cd05a4a2-ebab-4678-8175-c0fe4d788088

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '@ Title (Disease (NNDSS) + Metric)' = ```
			SELECTEDVALUE( NNDSS[DISEASE] ) & " - " & SELECTEDVALUE( Metrics[Metric] ) 
			```
		lineageTag: 6f03c3b4-eeea-454a-9d4c-cbecc2b83ac1

	measure '@ Title (Disease (NNDSS) + Metric + State)' = ```
			[@ Title (Disease (NNDSS) + Metric)] & " - " & SELECTEDVALUE( Geography[CODE] ) 
			```
		lineageTag: d8f99c08-a1b5-45ae-9986-d4e047b7b1f5

	measure '# New Cases (NNDSS) TEST' = ```
			
			VAR V_Year = VALUE ( MAX ( 'NNDSS'[YEAR] ) )
			VAR v_Previous =
			IF ( V_Year < 2024,
			    CALCULATE( [# Cases (NNDSS)] , 
			        OFFSET ( -1, 
			            ALL ( 'Dates' ) ,
			            ORDERBY ( 'Dates'[Date],ASC ), ,
			            PARTITIONBY ( Dates[Year] )
			        )
			    )
			)
			RETURN v_Previous 
			/*
			IF ( V_Year < "2024",
			    [# Cases (NNDSS)],
			    IF ( v_Previous > 0 && [# Cases (NNDSS)], [# Cases (NNDSS)] - v_Previous )
			)
			*/
			```
		lineageTag: d10a4ffd-3127-40d1-84b9-d97e89663f9a

		annotation PBI_FormatHint = {"isGeneralNumber":true}


	column 'Case Date' = ```
			
			VAR v_Report_Date_Latest = 
			CALCULATE( MAX ( NNDSS[Report Date] ), ALLEXCEPT( NNDSS, NNDSS[DISEASE] , NNDSS[YEAR], NNDSS[CODE] ) )
			RETURN
			SWITCH( TRUE(),
			    [Year of Report Date] > "", [Report Date], 
			    INT ( [YEAR] ) >= 2024, BLANK(),
			    [Report Date] = v_Report_Date_Latest, DATE ( [YEAR], 12, 31 ) 
			)
			```
		formatString: Short Date
		lineageTag: 32f2294f-21b3-482c-8b93-100c4330bb57
		summarizeBy: none

		annotation SummarizationSetBy = Automatic


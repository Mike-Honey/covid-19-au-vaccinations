				    "#,0"
				    )

	measure '# Metric Filter Outliers' = ```
			
			VAR v_Percentile = '^ Outlier Percentile'[^ Outlier Percentile Value] / 100
			RETURN
			SWITCH (
			    TRUE(),
			    v_Percentile = 0,
			    1,
			    CALCULATE (
			        PERCENTILEX.INC ( 'Dates' , [# Metric] , 1 - v_Percentile ),
			        ALLSELECTED ( 'Dates' )
			    ) >= [# Metric] &&
			    CALCULATE (
			        PERCENTILEX.INC ( 'Dates' , [# Metric] , v_Percentile ),
			        ALLSELECTED ( 'Dates' )
			    ) <= [# Metric] 
			    ,1
			    ,0
			)
			```

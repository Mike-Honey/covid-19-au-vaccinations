	measure '# Metric Sum' = SUMX ( DISTINCT( Dates[Date]), [# Metric] )
		lineageTag: e5310078-d440-40ac-b8ac-b01f0eea1635

		formatStringDefinition =
				VAR v_Metric = SELECTEDVALUE( Metrics[Metric] )

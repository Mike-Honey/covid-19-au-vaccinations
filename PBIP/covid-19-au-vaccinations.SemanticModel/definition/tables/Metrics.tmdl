		lineageTag: 4079801f-3fdd-4479-a538-20251c81bc63

		formatStringDefinition =
				VAR v_Metric = SELECTEDVALUE( Metrics[Metric] )
				RETURN
				SWITCH ( TRUE() ,
				    SEARCH( "%", v_Metric, 1, -1 ) > 0 , "0.0%",
				    SEARCH( " per ", v_Metric, 1, -1 ) > 0 , "#,0.0",
				    SEARCH( "avg", v_Metric, 1, -1 ) > 0 , "#,0.0",
				    SEARCH( "/", v_Metric, 1, -1 ) > 0 , "#,0.00",
				    "#,0"
				    )

	measure '# Metric Last' = LASTNONBLANKVALUE( Dates[Date], [# Metric] )
		lineageTag: d6c4f7fa-1315-4c88-9252-011e6d9f2770


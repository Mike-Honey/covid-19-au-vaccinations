	column 'Complete Week' = IF ( CALCULATE( DISTINCTCOUNT( Dates[Date] ), ALL( Dates ), Dates[End of Week] = EARLIER( Dates[End of Week] ) ) = 7 , "Complete Week", "Incomplete Week" )

	column 'Complete Day all States' =
			
			VAR v_Date = [Date]
			RETURN CALCULATE( COUNT( 'covid-live'[NEW_CASE_CNT] ), ALL( 'covid-live' ) , 'covid-live'[Report Date] = v_Date ) = 9
		formatString: """TRUE"";""TRUE"";""FALSE"""

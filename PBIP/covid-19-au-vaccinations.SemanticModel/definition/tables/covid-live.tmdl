	measure '# New Vaccination Doses (N-day rolling average)' = ```
			
			VAR v_End_Date = LASTDATE( 'covid-live'[Report Date] ) 
			VAR v_Start_Date = v_End_Date - ( [^ Rolling Average Days Value] - 1 )
			VAR v_End_Date_ADHAC = LASTDATE( 'ADHAC'[Report Date] ) 
			VAR v_Start_Date_ADHAC = v_End_Date_ADHAC - ( [^ Rolling Average Days Value] - 1 )
			RETURN
			IF ( [@ Data Source Label] = "covidlive.com.au", 
			    IF ( [# New Vaccination Doses] > 0 ,
			        CALCULATE (
			            SUMX( 
			                FILTER (
			                    Dates ,
			                    'Dates'[Date] >= v_Start_Date
			                        && 'Dates'[Date]  <= v_End_Date
			                ),
			                [# New Vaccination Doses] 
			            ) / [^ Rolling Average Days Value] ,
			            ALL( 'Dates' ),
			            ALL( 'covid-live'[Report Date] )
			        )
			    ),
			    IF ( [# New Vaccination Doses] > 0 ,
			        CALCULATE (
			            SUMX( 
			                FILTER (
			                    Dates ,
			                    'Dates'[Date] >= v_Start_Date_ADHAC
			                        && 'Dates'[Date]  <= v_End_Date_ADHAC
			                ),
			                [# New Vaccination Doses] 
			            ) / [^ Rolling Average Days Value] ,
			            ALL( 'Dates' ),
			            ALL( 'ADHAC'[Report Date] )
			        )
			    )
			)
			```

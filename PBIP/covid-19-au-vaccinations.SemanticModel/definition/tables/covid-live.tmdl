	measure 'Daily - New Doses' = ```
			
			IF ( [@ Data Source Label] = "covidlive.com.au", 
			    SUM ('covid-live'[VACC_DOSE_CNT] ) - SUM ('covid-live'[PREV_VACC_DOSE_CNT] ),
			    VAR v_Report_Date_Max = CALCULATE( MAX ( ADHAC[Report Date] ), ADHAC[Category] = "Boosters" )
			    RETURN CALCULATE( [# Value ADHAC], ADHAC[Category] = "Boosters" , ADHAC[Metric] <> "Booster Doses Rolling 7 Day Average" , ADHAC[Report Date] = v_Report_Date_Max )
			)
			```
		formatString: #,0
		lineageTag: a1468df0-b407-4358-842a-bdc883264ceb

		changedProperty = FormatString

		annotation PBI_FormatHint = {"isDecimal":true}

	measure '% Waning (6 months)' =
			
			VAR v_Return = CALCULATE( [% 2nd dose + 0] , DATEADD( Dates[Date] , -182, DAY ) )
			RETURN IF ( v_Return > 0 , v_Return )
		formatString: 0.0%;-0.0%;0.0%

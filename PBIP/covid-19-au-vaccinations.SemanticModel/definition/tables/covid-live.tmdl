	measure '# New Cases' = ```
			
			SWITCH ( [@ Data Source Label] ,
			    "covidlive.com.au", 
			        SUMX ( 'covid-live', 'covid-live'[CASE_CNT] - 'covid-live'[PREV_CASE_CNT] ),
			    "health.gov.au", 
			        CALCULATE( [# Value ADHAC], 
			            ADHAC[Metric] = "Daily Cases", 
			            FILTER ( DISTINCT(Dates[Date] ), NOT Dates[Date] IN { DATE ( 2024, 1, 17 ), DATE ( 2024, 2, 2 ) } )
			        ),
			    "NNDSS", 
			        [# New Cases (NNDSS)]
			)
			
			```
		lineageTag: e19c5225-0409-40c0-b99d-99d2ecaef878

		changedProperty = FormatString

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '# New Deaths' = ```
			
			IF ( [@ Data Source Label] = "covidlive.com.au", 
			    SUMX (
			        'covid-live',
			        IF (
			            [DEATH_CNT] - [PREV_DEATH_CNT] > 0,
			            [DEATH_CNT] - [PREV_DEATH_CNT],
			            0
			        ) 
			    ),
			    CALCULATE( [# Value ADHAC], ADHAC[Metric] = "Daily Deaths" ) 
			)
			```
		formatString: #,0
		lineageTag: 6455b1e4-ad3c-44d2-9aec-f32eeeb5682c

		changedProperty = FormatString

		annotation PBI_FormatHint = {"isDecimal":true}


	measure '% Cases Weekly Change' = ```
			
			VAR v_End_Date = 
			IF ( [@ Data Source Label] = "covidlive.com.au", 
			    CALCULATE ( LASTDATE( 'covid-live'[Report Date] ) , 'covid-live'[NEW_CASE_CNT] > 0 ),
			    CALCULATE ( LASTDATE( 'ADHAC'[Report Date] ) , ADHAC[Metric] = "Daily Cases" , ADHAC[Value] > 0 )
			)
			VAR v_Earliest_Date = 
			IF ( [@ Data Source Label] = "covidlive.com.au", 
			    CALCULATE ( FIRSTDATE( 'covid-live'[Report Date] ) , ALL ( 'covid-live'[Report Date] ) , 'covid-live'[Report Date] < v_End_Date ),
			    CALCULATE ( FIRSTDATE( 'ADHAC'[Report Date] ) , ALL ( 'ADHAC'[Report Date] ) , 'ADHAC'[Report Date] < v_End_Date )
			)
			RETURN
			    IF ( v_End_Date - v_Earliest_Date >= 13, 
			        DIVIDE( 
			            CALCULATE( [# Cases (N-day rolling average)] , 
			                ALL ( 'covid-live'[Report Date] ) , 
			                ALL ( 'ADHAC'[Report Date] ) , 
			                FILTER ( ALL ( Dates ) ,  
			                    'Dates'[Date] >= v_End_Date - 6 &&
			                     'Dates'[Date] <= v_End_Date
			                )
			            ),
			            CALCULATE( [# Cases (N-day rolling average)] , 
			                ALL ( 'covid-live'[Report Date] ) , 
			                ALL ( 'ADHAC'[Report Date] ) , 
			                FILTER ( ALL ( Dates ) ,  
			                    'Dates'[Date] >= v_End_Date - 13 &&
			                     'Dates'[Date] <= v_End_Date - 7
			                )
			            )
			        ) - 1
			    )
			```

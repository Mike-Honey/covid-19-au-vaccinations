			VAR v_End_Date = 'covid-live'[Report Date] 
			VAR v_Start_Date = v_End_Date - ( 6 )
			VAR v_CODE = [CODE]
			VAR v_End_Date_fwd = 
			    CALCULATE (
			        MINX( 
			            FILTER (
			                Dates ,
			                'Dates'[Date] >= v_End_Date 
			                    && ( ( v_CODE <> "AUS" && [# New Cases]  > 0 ) ||
			                        ( v_CODE = "AUS" && 'Dates'[Complete Day all States] = TRUE() ) )
			            ),
			            'Dates'[Date] 
			        ) ,
			        ALL( 'covid-live' ), 
			        'covid-live'[CODE] = v_CODE 
			    )
			RETURN
			IF ( v_CODE <> "AUS" || NOT ( ISBLANK( v_End_Date_fwd ) ) ,
			    IF ( 'covid-live'[NEW_CASE_CNT] > 0 && 'covid-live'[PREV_NEW_CASE_CNT] > 0 ,
			        'covid-live'[NEW_CASE_CNT] - 'covid-live'[NEW_PROB_CASE_CNT],
			        IF ( v_End_Date > DATE ( 2022, 9 , 9 ),
			            CALCULATE (
			                SUMX( 
			                    FILTER (
			                        Dates ,
			                        'Dates'[Date] >= v_End_Date
			                            && 'Dates'[Date]  <= v_End_Date_fwd
			                    ),
			                    [# New Cases (PCR)] 
			                ) / 7 ,
			                ALL( 'Dates' ),
			            ALLEXCEPT(  'covid-live', 'covid-live'[CODE], 'covid-live'[NAME] )
			            ),
			            CALCULATE (
			                SUMX( 
			                    FILTER (
			                        Dates ,
			                        'Dates'[Date] >= v_Start_Date
			                            && 'Dates'[Date]  <= v_End_Date
			                    ),
			                    [# New Cases (PCR)] 
			                ) / 7 ,
			                ALL( 'Dates' ),
			            ALLEXCEPT(  'covid-live', 'covid-live'[CODE], 'covid-live'[NAME] )
			            )
			        )
			    )
			)
			```

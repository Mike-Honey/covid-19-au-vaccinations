	measure '% Fully Vaccinated (boosted within 120 days)' = ```
			
			VAR v_Last_Date = LASTDATE( Dates[Date] )
			VAR v_3rd_doses_old = CALCULATE( [3rd+ doses], ALL( Dates ) , Dates[Date] = v_Last_Date - 120 )
			VAR v_3rd_doses_latest = CALCULATE( [3rd+ doses], ALL( Dates ) , Dates[Date] = v_Last_Date )
			VAR v_Return = 
			IF ( [@ Data Source Label] = "covidlive.com.au", 
			    v_3rd_doses_latest - v_3rd_doses_old,
			    SUMX ( FILTER( ALL ( 'Dates' ) , 'Dates'[Date] >= v_Last_Date - 120 && 'Dates'[Date] <= v_Last_Date ), [# New Vaccination Doses] )
			)
			RETURN 
			IF ( v_Return > 0 && [# Vaccination Doses] > 0, DIVIDE ( v_Return , [# Population] ) ) + 0
			
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: def7ec11-8edb-4018-9ce4-45a8148bac46

		changedProperty = FormatString

	measure '- Fully Vaccinated (boosted within 120 days)' =
			
			VAR v_Last_Date = LASTDATE( Dates[Date] ) - 120
			VAR v_3rd_doses_old = CALCULATE( [3rd+ doses] , Dates[Date] = v_Last_Date - 120, ALL( Dates ) )
			VAR v_3rd_doses_latest = CALCULATE( [3rd+ doses] , Dates[Date] = v_Last_Date, ALL( Dates ) )
			VAR v_Return = v_3rd_doses_latest - v_3rd_doses_old
			--RETURN IF ( v_Return > 0 , DIVIDE ( v_Return , [# Population] ) )
			RETURN v_Last_Date
		formatString: General Date
		lineageTag: f739a19e-2f80-4765-9d6b-6700887dc4a3

	measure '/ Reff' = ```
			
			VAR v_End_Date = 
			IF ( [@ Data Source Label] = "covidlive.com.au", 
			    CALCULATE ( LASTDATE( 'covid-live'[Report Date] ) , 'covid-live'[CASE_CNT] - 'covid-live'[PREV_CASE_CNT] > 0 ),
			    CALCULATE ( LASTDATE( 'ADHAC'[Report Date] ) , ADHAC[Metric] = "Daily Cases" , 'ADHAC'[Value] > 0 )
			)
			VAR v_Start_Date_1 = v_End_Date - 13 
			VAR v_End_Date_1 = v_End_Date - 7 
			VAR v_Start_Date = 
			IF ( [@ Data Source Label] = "covidlive.com.au", 
			    CALCULATE ( LASTDATE( 'covid-live'[Report Date] ) , ALL ( 'covid-live'[Report Date] ), ALL ( 'Dates' ) , 'covid-live'[Report Date] >= v_Start_Date_1, 'covid-live'[Report Date] <= v_End_Date_1, 'covid-live'[Cases changed] = "true" ),
			    CALCULATE ( LASTDATE( 'ADHAC'[Report Date] ) , ALL ( 'ADHAC'[Report Date] ) , 'ADHAC'[Report Date] < v_End_Date )
			)
			RETURN 
			    DIVIDE( [# Cases (N-day rolling average)] , 
			        CALCULATE( [# Cases (N-day rolling average)] , 
			            ALL ( Dates ) ,  
			            ALL ( 'covid-live'[Report Date] ) , 
			            ALL ( 'ADHAC'[Report Date] ) , 
			            ALL ( 'NNDSS'[Report Date] ) , 
			            'Dates'[Date] = v_Start_Date 
			        )
			    )
			```
		formatString: #,0.00
		lineageTag: 8481a2e4-b79a-4f72-bd93-d595e4504bd7

		changedProperty = FormatString


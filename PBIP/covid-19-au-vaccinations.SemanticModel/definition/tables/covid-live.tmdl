	measure '# Vaccination Boosters' = ```
			
			VAR v_Last_Date = LASTDATE( Dates[Date] ) 
			VAR v_Prior_Date = CALCULATE( LASTNONBLANKVALUE( Dates[Date], [3rd+ doses] ), ALL( Dates ), Dates[Date] < v_Last_Date ) 
			RETURN
			CALCULATE([3rd+ doses], ALL( Dates ), Dates[Date] = v_Last_Date ) -
			CALCULATE([3rd+ doses], ALL( Dates ), Dates[Date] = v_Prior_Date ) 
			--CALCULATE( SUM ( 'covid-live'[Total Vaccinations - Filled] ) - ( 2 * SUM( 'covid-live'[People Fully Vaccinated - Filled] ) ) , ALL( Dates ), Dates[Date] = v_Last_Date )

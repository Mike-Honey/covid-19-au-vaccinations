	measure '# Cases (Cumulative)' =
			
			VAR v_Year = MAX ( 'Dates'[Year] )
			RETURN
			CALCULATE(
				SUMX ( 'Dates' , [# New Cases] ),
				FILTER(
					ALLSELECTED('Dates'[Date]),
					ISONORAFTER('Dates'[Date], MAX('Dates'[Date]), DESC) &&
			        ( NOT ( ISINSCOPE( 'Dates'[Year] ) ) || YEAR ( [Date] ) = v_Year )
				)
			)

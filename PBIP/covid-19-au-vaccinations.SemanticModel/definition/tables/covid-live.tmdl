	column PREV_VACC_WINTER_CNT
		dataType: int64
		formatString: 0
		lineageTag: 34f636bf-d2aa-420b-aed4-4f4b67058a42
		summarizeBy: sum
		sourceColumn: PREV_VACC_WINTER_CNT

		annotation SummarizationSetBy = Automatic

	column 'New Cases (smoothed)' = ```
			
			VAR v_End_Date = 'covid-live'[Report Date] 
			VAR v_Start_Date = v_End_Date - ( 6 )
			VAR v_CODE = [CODE]
			VAR v_End_Date_fwd = 
			    CALCULATE (
			        MINX( 
			            FILTER (
			                Dates ,
			                'Dates'[Date] >= v_End_Date 
			                    && [# New Cases]  > 0 
			--                    && ( ( v_CODE <> "AUS" && [# New Cases]  > 0 ) ||
			--                        ( v_CODE = "AUS" && 'Dates'[Complete Day all States] = TRUE() ) )
			            ),
			            'Dates'[Date] 
			        ) ,
			        ALL( 'covid-live' ), 
			        'covid-live'[CODE] = v_CODE 
			    )
			RETURN
			IF ( v_CODE <> "AUS" || NOT ( ISBLANK( v_End_Date_fwd ) ) ,
			    IF ( ( 'covid-live'[NEW_CASE_CNT] > 0 && 'covid-live'[PREV_NEW_CASE_CNT] > 0 )  ,
			        'covid-live'[NEW_CASE_CNT],
			        IF ( v_End_Date > DATE ( 2022, 9 , 9 ) ,
			            CALCULATE (
			                DIVIDE (
			                    SUMX( 
			                        FILTER (
			                            Dates ,
			                            'Dates'[Date] >= v_End_Date
			                                && 'Dates'[Date]  <= v_End_Date_fwd
			                        ),
			                        [# New Cases] 
			                    ),
			                    v_End_Date_fwd - v_End_Date + 1 
			                ),
			                ALL( 'Dates' ),
			            ALLEXCEPT(  'covid-live', 'covid-live'[CODE], 'covid-live'[NAME] )
			            ),
			            CALCULATE (
			                DIVIDE(
			                    SUMX( 
			                        FILTER (
			                            Dates ,
			                            'Dates'[Date] >= v_Start_Date
			                                && 'Dates'[Date]  <= v_End_Date
			                        ),
			                        [# New Cases] 
			                    ) ,
			                    v_Start_Date - v_End_Date + 1 
			                ) ,
			                ALL( 'Dates' ),
			            ALLEXCEPT(  'covid-live', 'covid-live'[CODE], 'covid-live'[NAME] )
			            )
			        )
			    )
			)
			```
		lineageTag: 41c4f654-a736-4810-ab6f-ce43ecb786f6
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column v_End_Date_fwd = ```
			
			VAR v_End_Date = 'covid-live'[Report Date] 
			VAR v_Start_Date = v_End_Date - ( 6 )
			VAR v_CODE = [CODE]
			RETURN
			    CALCULATE (
			        MINX( 
			            FILTER (
			                Dates ,
			                'Dates'[Date] >= v_End_Date 
			                    && ( ( v_CODE <> "AUS" && [# New Cases]  > 0 ) ||
			                        ( v_CODE = "AUS" && 'Dates'[Complete Day all States] = TRUE() ) )
			            ),
			            'Dates'[Date] 
			        ) ,
			        ALL( 'covid-live' ), 
			        'covid-live'[CODE] = v_CODE 
			    )
			```
		formatString: General Date
		lineageTag: ad2303f4-ce2f-4c5c-854c-c0d35d3dbd45
		summarizeBy: none

		variation Variation
			isDefault
			relationship: 01eb5a99-4a4d-499f-bddb-d4429255945f
			defaultHierarchy: LocalDateTable_3fe8df68-0c7e-4569-9a1d-7ac473d41a86.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	column 'New Deaths (smoothed)' = ```
			
			VAR v_End_Date = 'covid-live'[Report Date] 
			VAR v_Start_Date = v_End_Date - ( 6 )
			VAR v_CODE = [CODE]
			VAR v_End_Date_fwd = 
			    CALCULATE (
			        MINX( 
			            FILTER (
			                Dates ,
			                'Dates'[Date] >= v_End_Date 
			                    && [# New Deaths]  > 0 
			--                    && ( ( v_CODE <> "AUS" && [# New Cases]  > 0 ) ||
			--                        ( v_CODE = "AUS" && 'Dates'[Complete Day all States] = TRUE() ) )
			            ),
			            'Dates'[Date] 
			        ) ,
			        ALL( 'covid-live' ), 
			        'covid-live'[CODE] = v_CODE 
			    )
			RETURN
			--IF ( v_CODE <> "AUS" || NOT ( ISBLANK( v_End_Date_fwd ) ) ,
			    IF ( ( 'covid-live'[DEATH_CNT] > 0 && 'covid-live'[PREV_DEATH_CNT] > 0 ),
			        [# New Deaths],
			        IF ( v_End_Date > DATE ( 2022, 9 , 9 ) ,
			            CALCULATE (
			                SUMX( 
			                    FILTER (
			                        Dates ,
			                        'Dates'[Date] >= v_End_Date
			                            && 'Dates'[Date]  <= v_End_Date_fwd
			                    ),
			                    [# New Deaths] 
			                ) / 7 ,
			                ALL( 'Dates' ),
			            ALLEXCEPT(  'covid-live', 'covid-live'[CODE], 'covid-live'[NAME] )
			            ),
			            CALCULATE (
			                SUMX( 
			                    FILTER (
			                        Dates ,
			                        'Dates'[Date] >= v_Start_Date
			                            && 'Dates'[Date]  <= v_End_Date
			                    ),
			                    [# New Deaths] 
			                ) / 7 ,
			                ALL( 'Dates' ),
			            ALLEXCEPT(  'covid-live', 'covid-live'[CODE], 'covid-live'[NAME] )
			            )
			        )
			    )
			--)
			```
		lineageTag: c66a85b2-5910-4c48-99de-b1c147e55316
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}


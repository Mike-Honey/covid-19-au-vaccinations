			    CALCULATE ( LASTDATE( 'covid-live'[Report Date] ) , 'covid-live'[MED_ICU_CNT] > 0 ),
			    CALCULATE ( LASTDATE( 'ADHAC'[Report Date] ) , ADHAC[Metric] = "7-Day Avg ICU" , 'ADHAC'[Value] > 0 )
			)
			VAR v_Earliest_Date = 

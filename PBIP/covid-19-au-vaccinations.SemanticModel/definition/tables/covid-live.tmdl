	measure '# Cases (N-day rolling average)' = ```
			
			VAR v_End_Date = LASTDATE( 'covid-live'[Report Date] ) 
			VAR v_Start_Date = v_End_Date - ( [^ Rolling Average Days Value] - 1 )
			RETURN
			IF ( [# New Cases] > 0 ,
			    CALCULATE (
			        SUMX( 
			            FILTER (
			                Dates ,
			                'Dates'[Date] >= v_Start_Date
			                    && 'Dates'[Date]  <= v_End_Date
			            ),
			            [# New Cases] 
			        ) / [^ Rolling Average Days Value] ,
			        ALL( 'Dates' ),
			        ALL( 'covid-live'[Report Date] ),
			        ALL( 'NNDSS'[Report Date] )
			    )
			)
			
			```
		formatString: #,#.#;#,#.#;0
		lineageTag: 345979a6-ca86-4040-880c-a2eaa27217d8

		changedProperty = FormatString

		annotation PBI_FormatHint = {"isCustom":true}


	measure '# Cases (1-year rolling average)' = ```
			
			VAR v_End_Date = LASTDATE( 'covid-live'[Report Date] ) 
			VAR v_Start_Date = v_End_Date - 364
			VAR v_Day_Range = v_End_Date - v_Start_Date
			RETURN
			IF ( [# New Cases] > 0 ,
			    CALCULATE (
			        SUMX( 
			            FILTER (
			                Dates ,
			                'Dates'[Date] >= v_Start_Date
			                    && 'Dates'[Date]  <= v_End_Date
			            ),
			            [# New Cases] 
			        ) / v_Day_Range ,
			        ALL( 'Dates' ),
			        ALL( 'covid-live'[Report Date] ),
			        ALL( 'NNDSS'[Report Date] )
			    )
			)
			
			```

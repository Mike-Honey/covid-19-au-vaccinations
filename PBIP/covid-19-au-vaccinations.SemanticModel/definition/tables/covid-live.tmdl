	measure '% Hospitalised Weekly Change' = ```
			
			VAR v_End_Date = 
			IF ( [@ Data Source Label] = "covidlive.com.au", 
			    CALCULATE ( LASTDATE( 'covid-live'[Report Date] ) , 'covid-live'[MED_HOSP_CNT] > 0 ),
			    CALCULATE ( LASTDATE( 'ADHAC'[Report Date] ) , ADHAC[Metric] = "7-Day Avg Hospitalised" , 'ADHAC'[Value] > 0 )
			)
			VAR v_Earliest_Date = 
			IF ( [@ Data Source Label] = "covidlive.com.au", 
			    CALCULATE ( FIRSTDATE( 'covid-live'[Report Date] ) , ALL ( 'covid-live'[Report Date] ) , 'covid-live'[Report Date] < v_End_Date ),
			    CALCULATE ( FIRSTDATE( 'ADHAC'[Report Date] ) , ALL ( 'ADHAC'[Report Date] ) , 'ADHAC'[Report Date] < v_End_Date )
			)
			RETURN
			    IF ( v_End_Date - v_Earliest_Date >= 13, 
			        DIVIDE( 
			            CALCULATE( LASTNONBLANKVALUE( 'Dates'[Date], [# Hospitalised] ) , 
			                ALL ( 'covid-live'[Report Date] ) , 
			                FILTER ( ALL ( Dates ) ,  
			                    'Dates'[Date] >= v_End_Date - 6 &&
			                     'Dates'[Date] <= v_End_Date
			                )
			            ),
			            CALCULATE( LASTNONBLANKVALUE( 'Dates'[Date], [# Hospitalised] ) , 
			                ALL ( 'covid-live'[Report Date] ) , 
			                FILTER ( ALL ( Dates ) ,  
			                    'Dates'[Date] >= v_End_Date - 13 &&
			                     'Dates'[Date] <= v_End_Date - 7
			                )
			            )
			        ) - 1
			    )
			```
		formatString: 0%;-0%;0%
		lineageTag: 6c6ea528-5887-40a8-9e8c-0199b1406f09

		changedProperty = FormatString

	measure '% ICU Weekly Change' = ```
			
			VAR v_End_Date = 

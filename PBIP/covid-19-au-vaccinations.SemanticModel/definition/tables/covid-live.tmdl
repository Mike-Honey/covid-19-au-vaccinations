	measure '% Fully Vaccinated (boosted within 120 days) v2' = ```
			
			VAR v_Last_Date = LASTDATE( Dates[Date] ) 
			VAR v_3rd_doses_old = CALCULATE( SUM ( 'covid-live'[Total Vaccinations - Filled] ) - ( 2 * SUM( 'covid-live'[People Fully Vaccinated - Filled] ) ) , ALL( Dates ), Dates[Date] = v_Last_Date - 120 )
			VAR v_3rd_doses_latest = CALCULATE( SUM ( 'covid-live'[Total Vaccinations - Filled] ) - ( 2 * SUM( 'covid-live'[People Fully Vaccinated - Filled] ) ) , ALL( Dates ), Dates[Date] = v_Last_Date )
			VAR v_Return = v_3rd_doses_latest - v_3rd_doses_old
			RETURN IF ( v_Return > 0 && [# Vaccination Doses] > 0, DIVIDE ( v_Return , [# Population] ) )
			```

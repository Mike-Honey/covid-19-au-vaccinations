	column 'Total Boosters - Filled' = ```
			
			VAR v_Location = [CODE]
			VAR v_Date = [Report Date]
			RETURN
			    CALCULATE (
			        LASTNONBLANKVALUE (
			            'covid-live'[Report Date],
			            MAX ( 'covid-live'[VACC_BOOSTER_CNT] )
			        ),
			        ALL ( 'covid-live' ),
			        'covid-live'[CODE] = v_Location,
			        'covid-live'[Report Date] <= v_Date
			    ) +
			    CALCULATE (
			        LASTNONBLANKVALUE (
			            'covid-live'[Report Date],
			            MAX ( 'covid-live'[VACC_WINTER_CNT] )
			        ),
			        ALL ( 'covid-live' ),
			        'covid-live'[CODE] = v_Location,
			        'covid-live'[Report Date] <= v_Date
			    )
			
			```
		formatString: 0
		lineageTag: 4db8cc4a-3448-48d3-beaf-6afa403a4b51
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Latest Date for Geography (Cases)' =
			
			VAR v_NAME = [NAME]
			VAR v_REPORT_DATE_Latest =  CALCULATE( LASTDATE( 'covid-live'[Report Date] ), ALL ( 'covid-live' ), 'covid-live'[NAME] = v_NAME, FILTER ( 'covid-live', [# New Cases] > 0 ) )
			RETURN IF ( [Report Date] = v_REPORT_DATE_Latest , "Latest" )
		lineageTag: 5854ffc1-f8b6-40f9-85b1-803d8aa7571c
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

